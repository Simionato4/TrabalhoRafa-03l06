# Copie este arquivo para .env e preencha com seus dados reais
# O arquivo .env NUNCA deve ser enviado ao GitHub

# --- Broker MQTT ---
MQTT_BROKER=Protondata.com.br
MQTT_PORT=1884
MQTT_USER=seu_usuario_mqtt
MQTT_PASS=sua_senha_mqtt
MQTT_TOPIC=casa/#
MQTT_CLIENT_ID=mqtt-bridge-01

# --- SQLite ---
# Caminho do arquivo do banco de dados (relativo ao script)
SQLITE_DB=mqtt_mensagens.db
